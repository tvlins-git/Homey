HOMEY_URL=https://YOUR_HOMEY_ID.connect.athom.com
HOMEY_TOKEN=

# Auth — seed admin on first boot (also accepts legacy DASHBOARD_PASSWORD)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# DASHBOARD_PASSWORD=   # legacy alias for ADMIN_PASSWORD
# SESSION_SECRET=       # optional; defaults to admin password

# Home detection (Phase 1) — leave unset to disable (dev-safe)
# Comma-separated home WAN IPs (check while on home WiFi)
HOME_WAN_IPS=
# Optional geofence fallback for cellular-at-home
HOME_LAT=
HOME_LNG=
HOME_RADIUS_M=150

# Upstash Redis / Vercel KV (Phase 2 user+ACL store). Falls back to in-memory if unset.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
