HOMEY_URL=https://YOUR_HOMEY_ID.connect.athom.com
HOMEY_TOKEN=

# Auth — seed admin on first boot (also accepts legacy DASHBOARD_PASSWORD)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# DASHBOARD_PASSWORD=   # legacy alias for ADMIN_PASSWORD
# SESSION_SECRET=       # optional; defaults to admin password

# Home detection — leave unset to disable (dev-safe)
# Comma-separated home WAN IPs or CIDRs (measure on home WiFi WITHOUT Private Relay/VPN)
# Example: HOME_WAN_IPS=90.227.83.182,2001:db8:abcd::/64
HOME_WAN_IPS=
# Optional geofence (falls back to Homey's own location if unset)
# Needed for iPhone Safari with iCloud Private Relay, which hides the home WAN IP
HOME_LAT=
HOME_LNG=
HOME_RADIUS_M=50

# Upstash Redis / Vercel KV (Phase 2 user+ACL store). Falls back to in-memory if unset.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
